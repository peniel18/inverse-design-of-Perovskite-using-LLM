# Optional global defaults. Project-specific values should usually live in
# `projects/<project-name>.env` and be generated by `./configure.sh --project <name>`.

# Shared Google Drive account that should be granted access to both folders.
REMOTE_ACCESS_EMAIL=compucatalysis@gmail.com

# Default project when REMOTE_PILOT_PROJECT is not set.
REMOTE_PILOT_PROJECT=default

# Directory holding per-project env files.
REMOTE_PILOT_PROJECT_ENV_DIR=$PWD/projects

# Shared rclone defaults.
RCLONE_REMOTE=gdrive:
RCLONE_CONFIG=

# Runtime behaviour.
SLEEP_SECS=45
INTERVAL_SEC=1800
TTL_HOURS=48
RUN_IN_BACKGROUND=1
MAX_CONCURRENT=1
COMMAND_TIMEOUT_SECS=240
COMMAND_TIMEOUT_KILL_GRACE_SECS=30
TIMEOUT_REQUEUE_TO_BG=1
PUBLISH_LOGS=1

# Mirror filter defaults used by sync_mirror.sh.
# Adjust these per project or override them in the shell before running
# `sync_mirror.sh` if you want to include/exclude different files.
SYNC_INCLUDE_GLOBS="results/** outputs/** logs/** *.out *.log *.txt"

# Optional notification settings for Slurm/HPC jobs.
SMTP_USER=arc.knust.job.notifier@gmail.com
SMTP_PASS=
NOTIFIER_PASSWORD_FILE=$HOME/.secrets/remote_pilot_gmail_app_password
NOTIFICATION_TO_PRIMARY=
NOTIFICATION_TO_SECONDARY=achenie@vt.edu
# Leave blank to fall back to PROJECT_NAME.
JOB_NOTIFICATION_NAME=
EMAIL_ON_START=1
FINISH_MARGIN_SECONDS=60
MAIL_LOG_FILES="slurm-\${SLURM_JOB_ID}.out /path/to/relay.log /path/to/supervisor.log"

# Default sync excludes for project-level mirroring.
SYNC_EXCLUDES=".git/** .remote-pilot/** state/** .env .relay.lock **/.relay.lock **/__pycache__/** *.tmp .*.swp"

# Optional transfer tuning for rclone operations.
# Example:
# RCLONE_EXTRA_FLAGS="--fast-list --transfers=16 --checkers=16"

# Optional tagged shell-variable pattern for users who do not want per-project files:
# PROJECT_A_PROJECT_DIR=/scratch/alice/project_a
# PROJECT_A_COMMAND_CHANNEL_FOLDER_ID=...
# PROJECT_A_MIRROR_ROOT_FOLDER_ID=...
